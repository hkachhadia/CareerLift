# ==========================================
# CareerLift Backend Environment Variables
# ==========================================

# 1. Server Configuration
PORT=5000
# The URL of your deployed Vercel frontend (e.g. https://careerlift.vercel.app)
CLIENT_URL=http://localhost:5173 

# 2. Database
# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/careerlift

# 3. Security
# A random, secure string used to sign JWT tokens (e.g. "supersecret12345")
JWT_SECRET=your_jwt_secret_key

# 4. AI Integration (Required)
# Get a free key from Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_flash_api_key

# 5. External APIs (Optional but recommended)
# Personal Access Token from GitHub to prevent rate-limiting on profile analysis
GITHUB_TOKEN=your_github_personal_access_token

# 6. OAuth Authentication (Optional if bypassing auth)
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Get these from GitHub Developer Settings
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
